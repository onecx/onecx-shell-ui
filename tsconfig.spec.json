{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "outDir": "./dist/out-tsc",
    "target": "es2016",
    "types": ["jest", "node"],
    "paths": {
      "@angular/common/http": ["./node_modules/@angular/common/types/http.d.ts"],
      "@angular/common/http/testing": ["./node_modules/@angular/common/types/http-testing.d.ts"],
      "@angular/platform-browser/animations": ["./node_modules/@angular/platform-browser/types/animations.d.ts"],
      "@onecx/angular-utils/style": ["./node_modules/@onecx/angular-utils/types/onecx-angular-utils-style.d.ts"],
      "@onecx/angular-integration-interface/mocks": ["./node_modules/@onecx/angular-integration-interface/types/onecx-angular-integration-interface-mocks.d.ts"],
      "primeng/api": ["./node_modules/primeng/types/primeng-api.d.ts"],
      "primeng/config": ["./node_modules/primeng/types/primeng-config.d.ts"],
      "primeng/toast": ["./node_modules/primeng/types/primeng-toast.d.ts"]
    }
  },
  "files": ["src/test-setup.ts"],
  "include": ["jest.config.ts", "src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.d.ts"]
}
